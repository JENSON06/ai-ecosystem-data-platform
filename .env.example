# Copy this file to .env and fill in your values
# cp .env.example .env

# GitHub API token — required
# Get one at: https://github.com/settings/tokens (no scopes needed for public repos)
# Without it: 60 requests/hour. With it: 5,000 requests/hour
GITHUB_TOKEN=your_github_pat_here

# HuggingFace token — optional, increases rate limits
HUGGINGFACE_TOKEN=your_hf_token_here

# Data lake path (local dev only — Docker overrides this via environment)
DATA_LAKE_PATH=./data_lake

# PostgreSQL — must match docker-compose.yml
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ai_platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform123

# PostgreSQL admin credentials (used by setup_db.py to create the DB and user)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=airflow
